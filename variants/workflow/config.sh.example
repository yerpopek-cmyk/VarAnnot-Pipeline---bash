#!/usr/bin/env bash
# =============================================================================
# variants/workflow/config.sh
# Single point of configuration for the pipeline.
# Copy this file as config.sh and edit it for your sample.
# =============================================================================

# --- Resources ---
THREADS=$(( $(nproc) > 2 ? $(nproc) - 2 : $(nproc) ))
MEM_SORT="4G"              # memory per thread for samtools sort

# --- Sample ---
SAMPLE_ID="sample01"

# --- Input Data ---
# Option A: Start from FASTQ
READS_R1="data/input/reads_R1.fastq.gz"
READS_R2="data/input/reads_R2.fastq.gz"
# Option B: Start from ready BAM (skip step 01)
# BAM_INPUT="data/input/sample.bam"

# --- Reference Genome ---
REF_FASTA="data/reference/ref.fasta"     # hg38 or chr22 for testing

# --- Databases for Annotation ---
VEP_CACHE_DIR="data/db/vep_cache"        # local VEP cache (~15 GB for hg38)
VEP_ASSEMBLY="GRCh38"                    # or GRCh37

# --- Filtering Thresholds ---
MIN_QUAL=30        # minimum QUAL
MIN_DP=10          # minimum depth of coverage
MAX_DP=250         # maximum depth (protection against repeats)
MIN_AB=0.20        # min allele balance for heterozygotes
MAX_AB=0.80        # max allele balance

# --- Reporting ---
TOP_VARIANTS=20    # number of top variants to include in the report
