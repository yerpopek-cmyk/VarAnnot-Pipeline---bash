#!/usr/bin/env bash
# =============================================================================
# variants/workflow/config.sh
# Единая точка настройки пайплайна.
# Скопируй этот файл как config.sh и отредактируй под свой образец.
# =============================================================================

# --- Ресурсы ---
THREADS=$(( $(nproc) > 2 ? $(nproc) - 2 : $(nproc) ))
MEM_SORT="4G"              # память на поток для samtools sort

# --- Образец ---
SAMPLE_ID="sample01"

# --- Входные данные ---
# Вариант A: начинаем с FASTQ
READS_R1="data/input/reads_R1.fastq.gz"
READS_R2="data/input/reads_R2.fastq.gz"
# Вариант B: начинаем с готового BAM (тогда пропускаем шаг 01)
# BAM_INPUT="data/input/sample.bam"

# --- Референсный геном ---
REF_FASTA="data/reference/ref.fasta"     # hg38 или chr22 для теста

# --- Базы данных для аннотации ---
VEP_CACHE_DIR="data/db/vep_cache"        # локальный кэш VEP (~15 ГБ для hg38)
VEP_ASSEMBLY="GRCh38"                    # или GRCh37

# --- Пороги фильтрации ---
MIN_QUAL=30        # минимальный QUAL
MIN_DP=10          # минимальная глубина покрытия
MAX_DP=250         # максимальная глубина (защита от повторов)
MIN_AB=0.20        # мин. allele balance для гетерозигот
MAX_AB=0.80        # макс.

# --- Отчёт ---
TOP_VARIANTS=20    # сколько топ-вариантов выводить в отчёт
